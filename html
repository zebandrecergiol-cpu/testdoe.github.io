<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Qbay Career | Global Career, Authenticated</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #020617; }
        .glass-pill { backdrop-filter: blur(30px); background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); }
        @keyframes breathing {
            0%, 100% { transform: scale(1); box-shadow: 0 0 0px rgba(59, 130, 246, 0); }
            50% { transform: scale(1.05); box-shadow: 0 0 20px rgba(59, 130, 246, 0.4); }
        }
        .animate-breathing { animation: breathing 10s ease-in-out infinite; }
        .shimmer { position: relative; overflow: hidden; }
        .shimmer::after {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: linear-gradient(45deg, transparent, rgba(255,255,255,0.1), transparent);
            transform: rotate(45deg); animation: shimmer-move 4s infinite;
        }
        @keyframes shimmer-move { 0% { transform: translateX(-100%) rotate(45deg); } 100% { transform: translateX(100%) rotate(45deg); } }
    </style>
</head>
<body x-data="{ scrolled: false }" @scroll.window="scrolled = (window.pageYOffset > 50)">

    <header :class="scrolled ? 'fixed top-5 left-1/2 -translate-x-1/2 w-[60%] rounded-full px-8 py-3 glass-pill shadow-2xl' : 'absolute top-0 left-0 w-full px-12 py-6 border-b border-white/10'"
            class="z-50 flex items-center justify-between transition-all duration-700 ease-in-out">
        
        <div class="flex items-center">
            <img src="https://qbaycareer.com/wp-content/uploads/2023/07/Qbay-Logo-White.png" alt="Qbay Logo" class="h-8 md:h-10 transition-all duration-500">
        </div>

        <nav class="hidden md:flex gap-10 text-white/80 text-sm font-medium tracking-wide">
            <a href="#" class="hover:text-white transition">Home</a>
            <a href="#" class="hover:text-white transition">About Us</a>
            <a href="#" class="hover:text-white transition">Pricing</a>
            <a href="#" class="hover:text-white transition">Wall of Fame</a>
            <a href="#" class="hover:text-white transition">Blog</a>
        </nav>
    </header>

    <section class="relative h-screen flex flex-col items-center justify-center overflow-hidden">
        <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover opacity-50 pointer-events-none" style="filter: brightness(0.6);">
            <source src="sovereign-collision.mp4" type="video/mp4">
        </video>

        <div class="z-10 mb-8 flex flex-wrap justify-center gap-3 -ml-16">
            <template x-for="pill in ['100k+ Helped', 'Trustpilot 4.8 ★', '90-Day Calls', 'Gov Approved (UK/Finland)', '29 Countries']">
                <div class="px-5 py-2 glass-pill rounded-full text-white text-[11px] uppercase tracking-widest shimmer shadow-inner">
                    <span x-text="pill"></span>
                </div>
            </template>
        </div>

        <div x-intersect="$el.classList.add('opacity-100')" class="z-10 text-center transition-opacity duration-1000">
            <h1 class="text-white text-5xl md:text-8xl font-bold tracking-tighter leading-none mb-6">
                Your Global Career,<br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300">Authenticated.</span>
            </h1>
        </div>

        <div :class="scrolled ? 'fixed top-[88px] opacity-100 scale-100' : 'relative opacity-100 scale-105'"
             class="z-40 flex shadow-2xl transition-all duration-500 ease-out -ml-20">
            <a href="#" class="flex items-center gap-3 bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-l-xl font-bold animate-breathing border-r border-white/10">
                <img src="https://www.gstatic.com/images/branding/product/2x/google_meet_96dp.png" class="w-5" alt="Meet"> Book Strategy Call
            </a>
            <a href="#" class="flex items-center gap-3 bg-[#25D366] hover:bg-green-600 text-white px-8 py-4 rounded-r-xl font-bold animate-breathing">
                <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" class="w-5" alt="WhatsApp"> WhatsApp Now
            </a>
        </div>
    </section>

    <section class="relative py-32 px-6 flex justify-center bg-[#020617]">
        <div class="max-w-4xl w-full bg-[#0a192f]/80 backdrop-blur-xl border border-blue-400/30 rounded-3xl p-12 flex flex-col md:flex-row items-center gap-12 shadow-[0_0_80px_rgba(59,130,246,0.15)] shimmer">
            <div class="relative">
                <div class="absolute -inset-1 bg-gradient-to-r from-blue-500 to-cyan-500 rounded-2xl blur opacity-25"></div>
                <img src="founder-portrait.jpg" class="relative w-56 h-56 rounded-2xl object-cover grayscale hover:grayscale-0 transition-all duration-700 shadow-2xl" alt="Qbay Founder">
            </div>
            <div class="text-left flex-1">
                <h3 class="text-blue-400 text-sm font-bold uppercase tracking-widest mb-2">Executive Invitation</h3>
                <h2 class="text-white text-4xl font-bold mb-6">Complimentary Strategy Consult</h2>
                <p class="text-slate-400 text-lg mb-8 leading-relaxed italic">"Our mission is to bridge the gap between regional talent and global opportunity through verified, high-authority pathways."</p>
                <div class="inline-flex items-center gap-4 px-6 py-3 bg-white/5 border border-white/10 rounded-lg">
                    <span class="text-slate-500 line-through">Value: €99</span>
                    <span class="text-green-400 font-bold">Complimentary for VIP</span>
                </div>
            </div>
        </div>
    </section>

</body>
</html>
